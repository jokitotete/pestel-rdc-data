{
  "expo": {
    "name": "RDC · Veille",
    "slug": "pestel-rdc",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#f4f1ea",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "consulting.twoid.pestelrdc"
    },
    "android": {
      "package": "consulting.twoid.pestelrdc",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2f52e0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2f52e0"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ffde5cee-bc82-465c-8a89-a4d05445e94b"
      }
    }
  }
}
